{
  "name": "mathieulalonde.com",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "import_posts": "node public/import_posts.cjs",
    "postcss:run": "postcss src/style.css -d dist public",
    "postcss:watch": "postcss src/style.css -d dist public --watch",
    "postcss:build": "postcss dist/**/*.css -d dist",
    "purgecss": "purgecss --css dist/**/*.css --content dist/**/*.!(css) --output dist/test",
    "watchsass": "sass --watch src/sass:dist/css"
  },
  "browserslist": [
    "defaults"
  ],
  "dependencies": {
    "markdown-to-jsx": "^9.7.15",
    "normalize.css": "^8.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.14.0",
    "react-slugify": "^5.0.0",
    "react-syntax-highlighter": "^16.1.1",
    "refractor": "^5.0.0",
    "sass": "^1.99.0",
    "slugify": "^1.6.9"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.1.1",
    "@eslint-react/eslint-plugin": "^3.0.0",
    "@fullhuman/postcss-purgecss": "^8.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "cssnano": "^7.1.4",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "7.1.0-canary-705268dc-20260409",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.9",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "prismjs": "^1.30.0"
  }
}
